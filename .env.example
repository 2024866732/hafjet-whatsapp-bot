# HAFJET WhatsApp Bot — Environment Variables
# Copy this to ~/.hermes/.env and fill in the values

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
APP_SECRET=your_app_secret_here
WEBHOOK_VERIFY_TOKEN=hafjet_verify_2026

# Server
WEBHOOK_PORT=8443
